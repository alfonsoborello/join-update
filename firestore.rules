rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "alfonsoborello@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'poeticKey', 'role']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email == request.auth.token.email &&
             (data.displayName == null || data.displayName is string) &&
             (data.preferredLanguage == null || data.preferredLanguage is string) &&
             data.poeticKey is string && data.poeticKey.size() > 0 &&
             data.role in ['admin', 'user'];
    }

    function isValidPublicUpdate(data) {
      return data.keys().hasAll(['content', 'timestamp', 'authorUid']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.timestamp is timestamp &&
             data.authorUid == request.auth.uid;
    }

    function isValidPrivateUpdate(data) {
      return data.keys().hasAll(['content', 'timestamp', 'senderUid', 'recipientUid', 'senderKey', 'recipientKey']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.timestamp is timestamp &&
             data.senderUid == request.auth.uid &&
             data.recipientUid is string &&
             data.senderKey is string &&
             data.recipientKey is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['timestamp', 'senderKey', 'type']) &&
             data.timestamp is timestamp &&
             data.senderKey is string &&
             data.type in ['public', 'private'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && 
                      request.resource.data.role == resource.data.role;
    }

    match /publicUpdates/{updateId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /privateUpdates/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderUid || request.auth.uid == resource.data.recipientUid);
      allow create: if isAuthenticated() && isValidPrivateUpdate(request.resource.data);
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
    }
  }
}
